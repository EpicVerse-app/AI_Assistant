# Copy to .env and fill in your keys (never commit .env)

# PostgreSQL (docker compose sets this for the api service automatically)
# DATABASE_URL=postgresql+psycopg2://ai_assistant:ai_assistant@localhost:5432/ai_assistant
# Omit DATABASE_URL to fall back to SQLite at backend/database/ai_assistant.db

SARVAM_API_KEY=your_sarvam_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# API authentication
# JWT_SECRET=generate_a_long_random_secret_at_least_32_chars
# JWT_EXPIRE_HOURS=168
# AUTH_LOGIN_RATE=5/minute
# AUTH_REGISTER_RATE=10/hour

# CORS — comma-separated list of allowed origins (no trailing slash).
# Leave unset or "*" only for local dev; always set explicitly in production.
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Logging
# LOG_FORMAT=json    # json = structured JSON for CloudWatch; text = human-readable (default)
# LOG_LEVEL=INFO     # DEBUG / INFO / WARNING / ERROR

# Max upload size in bytes. Default is ~604 MB (5 hours of 16 kHz mono WAV + 10% headroom).
# MAX_UPLOAD_BYTES=633600000

# Rate limiting storage — use Redis in production so limits are shared across instances.
# docker compose sets this automatically via the redis service.
# RATE_LIMIT_STORAGE_URI=redis://:your_auth_token@your-redis-host:6379/0

# Storage: local (default) or s3
# STORAGE_BACKEND=local
# STORAGE_BUCKET=your-bucket-name
# STORAGE_AUDIO_PREFIX=audio
# STORAGE_MEETINGS_PREFIX=meetings
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=
