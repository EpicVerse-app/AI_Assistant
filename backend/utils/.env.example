# Copy to .env and fill in your keys (never commit .env)

# PostgreSQL (docker compose sets this for the api service automatically)
# For local uvicorn outside Docker, use localhost:
# DATABASE_URL=postgresql+psycopg2://ai_assistant:ai_assistant@localhost:5432/ai_assistant
# Omit DATABASE_URL to fall back to SQLite at backend/database/ai_assistant.db

SARVAM_API_KEY=your_sarvam_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
