# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

# ── General ───────────────────────────────────────────────────────────────────
aws_region   = "ap-south-1"
project_name = "ai-assistant"
environment  = "production"

# ── Networking ────────────────────────────────────────────────────────────────
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# Request a certificate in ACM first:
#   AWS Console → Certificate Manager → Request → add api.yourdomain.com → DNS validation
# Then paste the ARN here.
acm_certificate_arn = "arn:aws:acm:ap-south-1:123456789012:certificate/REPLACE_ME"
domain_name         = "api.yourdomain.com"

# CORS — comma-separated list of allowed origins (your Flutter app's domain).
allowed_origins = "https://yourdomain.com,https://app.yourdomain.com"

# ── ECS ───────────────────────────────────────────────────────────────────────
app_image_tag     = "latest"   # replace with a git SHA for proper deploys
app_cpu           = 512        # 0.5 vCPU
app_memory        = 1024       # 1 GB
app_desired_count = 1

# ── RDS ───────────────────────────────────────────────────────────────────────
db_instance_class    = "db.t4g.micro"
db_allocated_storage = 20
db_name              = "ai_assistant"
db_username          = "ai_assistant"

# ── ElastiCache ───────────────────────────────────────────────────────────────
redis_node_type = "cache.t4g.micro"
